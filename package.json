{
  "name": "ghostwatch",
  "version": "0.1.0",
  "description": "Open-source, lightweight monitoring for APIs and services",
  "private": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jaimegcaam/ghostwatch.git"
  },
  "keywords": [
    "monitoring",
    "uptime",
    "api",
    "status-page",
    "open-source",
    "alerts",
    "observability"
  ],
  "scripts": {
    "dev": "next dev",
    "cron": "node --env-file=.env scripts/local-cron.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "setup": "node scripts/setup.mjs",
    "db:up": "docker compose -f docker-compose.dev.yml up -d",
    "db:down": "docker compose -f docker-compose.dev.yml down",
    "db:migrate": "prisma migrate deploy",
    "db:migrate:dev": "prisma migrate dev",
    "db:studio": "prisma studio",
    "docker:setup": "node scripts/docker-setup.mjs",
    "docker:init": "node scripts/docker-setup.mjs && docker compose up -d",
    "docker:build": "DOCKER_BUILDKIT=1 docker build -t ghostwatch:latest .",
    "docker:up": "docker compose up -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f app",
    "docker:regions:build": "DOCKER_BUILDKIT=1 docker compose -f docker-compose.regions.yml build hub",
    "docker:regions:up": "docker compose -f docker-compose.regions.yml up -d --no-build hub probe-us probe-es",
    "docker:regions:restart": "npm run docker:regions:build && npm run docker:regions:up"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@boxyhq/saml-jackson": "^26.2.0",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.6.0",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.8",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toast": "^1.2.15",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@vercel/blob": "^2.4.0",
    "bcryptjs": "^3.0.3",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.1.0",
    "dotenv": "^17.4.1",
    "lucide-react": "^1.7.0",
    "nanoid": "^3.3.11",
    "next": "16.2.2",
    "next-auth": "^5.0.0-beta.30",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "recharts": "^3.8.1",
    "resend": "^6.10.0",
    "tailwind-merge": "^3.5.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.2",
    "tailwindcss": "^4",
    "typescript": "^5"
  }
}
