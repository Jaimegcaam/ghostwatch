# =============================================================================
#  Ghostwatch — environment variables
#  Quickest path: npm run setup
# =============================================================================

# --- Required ----------------------------------------------------------------
DATABASE_URL="postgresql://ghostwatch:ghostwatch@localhost:5432/ghostwatch?schema=public"
NEXTAUTH_URL="http://localhost:3000"
APP_HOST="localhost"
AUTH_SECRET="replace-me"
CRON_SECRET="replace-me"
AUTH_TRUST_HOST="true"

# --- Optional ----------------------------------------------------------------
STATUS_CNAME_TARGET=""
OWNER_EMAIL=""
OPEN_REGISTRATION="false"
SELF_HOSTED="true"
ENABLE_BUILTIN_SCHEDULER="true"
CRON_INTERVAL_MS="60000"
PROBE_REGION="local"
PROBE_REGION_LABEL=""
MONITORING_REGIONS=""
DEFAULT_REGION=""
PROBE_ENDPOINTS=""
STATUS_OUTAGE_THRESHOLD="3"

# --- Email (optional) --------------------------------------------------------
RESEND_API_KEY=""
FROM_EMAIL="Ghostwatch <onboarding@resend.dev>"

# --- OAuth (optional) --------------------------------------------------------
# Set ENABLE_OAUTH=true and fill provider credentials to show Google/GitHub buttons.
ENABLE_OAUTH="false"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_ID=""
GITHUB_SECRET=""

# --- Uploads (Vercel / serverless) -------------------------------------------
# Required on Vercel for status-page logos and team images. Create a Blob store
# in Vercel → Storage, then link it to get BLOB_READ_WRITE_TOKEN.
# Docker / self-hosted: leave unset — files are stored in public/uploads.
# BLOB_READ_WRITE_TOKEN=""

# Full reference: docs/CONFIGURATION.md
