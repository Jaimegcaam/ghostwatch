# Ghostwatch — Docker Compose
# Quick start: see docs/GETTING-STARTED.md
#   ./scripts/docker-setup.sh && docker compose up -d
#   — or — npm run docker:init

# --- App URL (change for production) -----------------------------------------
NEXTAUTH_URL=http://localhost:3000
APP_HOST=localhost
APP_PORT=3000
STATUS_CNAME_TARGET=

# --- Secrets (auto-filled by npm run docker:setup) ---------------------------
AUTH_SECRET=replace-with-openssl-rand-base64-32
AUTH_TRUST_HOST=true
CRON_SECRET=replace-with-openssl-rand-base64-32

# --- Owner (optional) --------------------------------------------------------
OWNER_EMAIL=

# --- Multi-region (optional — see docs/deploy/docker-multi-region.md) --------
# PROBE_ENDPOINTS=us-east-1|https://probe-va.corp.com|North Virginia,eu-south-2|https://probe-madrid.corp.com|Spain
# DEFAULT_REGION=us-east-1

# --- Postgres (auto-used by compose) -----------------------------------------
POSTGRES_USER=ghostwatch
POSTGRES_PASSWORD=change-me-please
POSTGRES_DB=ghostwatch

# --- Email (optional) --------------------------------------------------------
RESEND_API_KEY=
FROM_EMAIL=Ghostwatch <onboarding@resend.dev>

# --- OAuth (optional) --------------------------------------------------------
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GITHUB_ID=
GITHUB_SECRET=
