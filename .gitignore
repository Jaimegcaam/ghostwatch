# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*
!.env.example
!.env.docker.example

# vercel (local deploy config — not committed)
.vercel
vercel.json
.vercelignore
.env.vercel

# editor / local workspace
*.code-workspace

# typescript
*.tsbuildinfo
next-env.d.ts

# generated prisma client
/src/generated/prisma

# user uploads (keep the directory, ignore uploaded files)
/public/uploads/*
!/public/uploads/.gitkeep
